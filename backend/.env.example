# =====================================================
# Funding Finder V2 — Backend Environment Variables
# =====================================================
# Скопируй в .env и заполни реальными значениями
# =====================================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/funding_finder"

# Server
PORT=3000
NODE_ENV=development

# Telegram — ОБЯЗАТЕЛЬНО
TELEGRAM_BOT_TOKEN=your_bot_token_here

# JWT Secret — ОБЯЗАТЕЛЬНО
# Сгенерируй: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-random-64-chars

# AI — OpenRouter (необязательно). Используются ТОЛЬКО бесплатные модели (":free").
# Ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Основная модель (должна оканчиваться на :free)
AI_MODEL=deepseek/deepseek-chat-v3-0324:free
# Цепочка фолбэков (через запятую, только :free). Список бесплатных моделей
# также подтягивается автоматически из OpenRouter, недоступные пропускаются.
AI_MODELS=deepseek/deepseek-chat-v3-0324:free,meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free,qwen/qwen-2.5-72b-instruct:free,mistralai/mistral-small-3.1-24b-instruct:free
# Атрибуция для OpenRouter (заголовки HTTP-Referer / X-Title)
AI_APP_URL=https://funding-finder-frontend.onrender.com
AI_APP_TITLE=Funding Finder

# Exchange defaults
SETTLE=usdt
MIN_FUNDING_ABS=0.0005
MIN_VOLUME_24H=1000

# Crypto Pay (необязательно)
CRYPTO_PAY_API_TOKEN=your_crypto_pay_token_here
CRYPTO_BOT_USERNAME=CryptoBot
CRYPTO_PAY_NETWORK=testnet

# Webhook Secret — ОБЯЗАТЕЛЬНО
WEBHOOK_SECRET=change-me-to-random-64-chars

# Redis connection (optional, for job queues)
REDIS_URL=redis://localhost:6379

# Admin (telegram IDs через запятую — кто может заходить в /admin)
ADMIN_TELEGRAM_IDS=

# Sentry (мониторинг ошибок, опционально)
SENTRY_DSN=

# CORS (через запятую)
CORS_ORIGINS=https://t.me,https://telegram.org

# Email (SMTP, optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Funding Finder <noreply@fundingfinder.app>
