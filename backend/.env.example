# =====================================================
# Funding Finder V2 — Backend Environment Variables
# =====================================================
# Скопируй в .env и заполни реальными значениями
# =====================================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/funding_finder"
# Direct (non-pooled) URL for Prisma migrations / shadow DB (optional in dev)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/funding_finder"

# Server
PORT=3000
NODE_ENV=development

# Telegram — ОБЯЗАТЕЛЬНО
TELEGRAM_BOT_TOKEN=your_bot_token_here

# JWT Secret — ОБЯЗАТЕЛЬНО
# Сгенерируй: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-random-64-chars

# AI — OpenRouter (необязательно). Используются ТОЛЬКО бесплатные модели (":free").
# Ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
# Основная модель (должна оканчиваться на :free)
AI_MODEL=deepseek/deepseek-chat-v3-0324:free
# Цепочка фолбэков (через запятую, только :free). Список бесплатных моделей
# также подтягивается автоматически из OpenRouter, недоступные пропускаются.
AI_MODELS=deepseek/deepseek-chat-v3-0324:free,meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free,qwen/qwen-2.5-72b-instruct:free,mistralai/mistral-small-3.1-24b-instruct:free
# Атрибуция для OpenRouter (заголовки HTTP-Referer / X-Title)
AI_APP_URL=https://funding-finder-frontend.onrender.com
AI_APP_TITLE=Funding Finder

# Exchange defaults
SETTLE=usdt
MIN_FUNDING_ABS=0.0005
MIN_VOLUME_24H=1000

# Crypto Pay (необязательно, для Telegram MiniApp)
CRYPTO_PAY_API_TOKEN=your_crypto_pay_token_here
CRYPTO_BOT_USERNAME=CryptoBot
CRYPTO_PAY_NETWORK=testnet

# NOWPayments (крипто-оплата для веб-сайта, без Telegram)
# https://nowpayments.io/dashboard
NOWPAYMENTS_API_KEY=your_nowpayments_api_key_here
# IPN (Instant Payment Notification) секрет — проверка подписи webhook (HMAC-SHA512)
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret_here
# Среда NOWPayments: sandbox (тест) | live (прод). НЕ путать с сетью вывода.
NOWPAYMENTS_NETWORK=sandbox
# Базовый URL API (нужен для callback IPN, чтобы сверить платёж)
API_BASE_URL=https://funding-finder-api.onrender.com

# Google OAuth (вход через Google на сайте, необязательно)
# https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Web Auth (вход через кошелёк SIWE / Google на сайте)
# Домен, который подписывается в SIWE-сообщении (должен совпадать с доменом сайта)
WEB_AUTH_DOMAIN=funding-finder.onrender.com
# Время жизни SIWE-nonce в минутах
SIWE_EXPIRATION_MINUTES=10
# Время жизни JWT для веб-сессии (в секундах)
JWT_WEB_TTL=2592000

# Webhook Secret — ОБЯЗАТЕЛЬНО
WEBHOOK_SECRET=change-me-to-random-64-chars

# Encryption key — ОБЯЗАТЕЛЬНО в production (шифрование API-ключей бирж, AES-256-GCM)
# Сгенерируй: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-random-32-chars-min

# Redis connection (optional, for job queues)
REDIS_URL=redis://localhost:6379

# Admin (telegram IDs через запятую — кто может заходить в /admin)
ADMIN_TELEGRAM_IDS=

# Sentry (мониторинг ошибок, опционально)
SENTRY_DSN=

# CORS (через запятую) — добавь домен фронтенда/сайта
CORS_ORIGINS=https://t.me,https://telegram.org,https://funding-finder.onrender.com

# Email (SMTP, optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Funding Finder <noreply@fundingfinder.app>

# Pushover push notifications (https://pushover.net) - optional
PUSHOVER_TOKEN=

# Public marketing signal channel (organic lead-gen, optional).
# Set to a Telegram chat_id or @channelusername. The bot will post the top
# arbitrage opportunity there every 30 min to grow an audience for free.
# Leave empty to disable.
PUBLIC_SIGNAL_CHANNEL=
