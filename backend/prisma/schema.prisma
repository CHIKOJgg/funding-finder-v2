generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String   @id @default(cuid())
  telegramId     String   @unique
  username       String?
  firstName      String?
  role           String   @default("user")
  subscription   String   @default("free")
  trialUsed      Boolean  @default(false)
  trialEndsAt    DateTime?
  trialScans     Int      @default(1)
  referralCode   String   @unique @default(cuid())
  referredBy     String?
  referrer       User?    @relation("Referrals", fields: [referredBy], references: [id])
  referrals      User[]   @relation("Referrals")
  balance        Float    @default(0)
  lastActive     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders          Order[]
  withdrawals     Withdrawal[]
  paymentHistory  PaymentHistory[]
  generalAlerts   GeneralAlert[]
  arbitrageAlerts ArbitrageAlert[]
  settings        UserSettings?
  watchlist       WatchlistItem[]
  positions       PortfolioPosition[]
  apiKeys         ApiKey[]
  executedOrders  ExecutedOrder[]

  @@index([role])
  @@index([subscription])
  @@index([createdAt])
  @@index([lastActive])
}

model UserSettings {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [telegramId])
  telegramNotifications  Boolean  @default(true)
  emailNotifications     Boolean  @default(false)
  emailAddress           String?
  dailySummary           Boolean  @default(true)
  alertSound             Boolean  @default(true)
  defaultExchanges       String[] @default(["gate", "binance", "bybit", "mexc", "okx"])
  theme                  String   @default("auto")
  language               String   @default("ru")
  timezone               String   @default("Europe/Moscow")
  minVolumeFilter        Float    @default(1000)
  minRateFilter          Float    @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Order {
  id          String   @id @default(cuid())
  planId      String
  userId      String
  user        User     @relation(fields: [userId], references: [telegramId])
  amount      Float
  currency    String   @default("USDT")
  status      String   @default("pending")
  invoiceId   String?
  invoice     Invoice?
  transactionId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Invoice {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])
  invoiceId       String?
  hash            String?
  botInvoiceUrl   String?
  miniAppInvoiceUrl String?
  webAppInvoiceUrl  String?
  status          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([invoiceId])
}

model Withdrawal {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [telegramId])
  amount        Float
  currency      String
  address       String
  network       String
  status        String   @default("pending")
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model PaymentHistory {
  id      String @id @default(cuid())
  userId  String @unique
  user    User   @relation(fields: [userId], references: [telegramId])
  payments PaymentRecord[]
}

model PaymentRecord {
  id               String @id @default(cuid())
  paymentHistoryId String
  paymentHistory   PaymentHistory @relation(fields: [paymentHistoryId], references: [id])
  orderId          String?
  plan             String
  amount           Float
  currency         String
  date             DateTime @default(now())

  @@index([paymentHistoryId])
}

model GeneralAlert {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [telegramId])
  pair         String
  exchange     String
  condition    String
  threshold    Float
  isActive     Boolean  @default(true)
  cooldown     Int      @default(300000)
  lastTriggered DateTime?
  triggerCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([exchange, pair])
}

model ArbitrageAlert {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [telegramId])
  pair         String
  exchangeA    String
  exchangeB    String
  condition    String   @default("difference")
  threshold    Float    @default(0.002)
  direction    String   @default("both")
  isActive     Boolean  @default(true)
  cooldown     Int      @default(300000)
  lastTriggered DateTime?
  triggerCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([isActive])
  @@index([pair, exchangeA, exchangeB])
}

model FundingHistory {
  id      String   @id @default(cuid())
  key     String   @unique
  records FundingRecord[]

  @@index([key])
}

model FundingRecord {
  id                String @id @default(cuid())
  fundingHistoryId  String
  fundingHistory    FundingHistory @relation(fields: [fundingHistoryId], references: [id])
  timestamp         DateTime @default(now())
  funding           Float

  @@index([fundingHistoryId])
  @@index([timestamp])
}

model AlertTrigger {
  id          String   @id @default(cuid())
  alertId     String
  alertType   String   // 'general' | 'arbitrage'
  triggeredAt DateTime @default(now())
  data        String?  // JSON string with alert details

  @@index([alertId])
  @@index([triggeredAt])
}

model ContractMetadata {
  id              String   @id @default(cuid())
  key             String   @unique  // exchange:contract
  exchange        String
  contract        String
  settleCurrency  String   @default("usdt")
  baseCurrency    String?
  quoteCurrency   String?
  tickSize        Float?
  minQty         Float?
  maxLeverage    Int?
  fundingCap     Float?
  fundingFloor   Float?
  openInterest   Float?
  lastUpdated    DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([exchange])
  @@index([baseCurrency])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [telegramId], onDelete: Cascade)
  exchange  String
  pair      String
  createdAt DateTime @default(now())

  @@unique([userId, exchange, pair])
  @@index([userId])
  @@index([exchange, pair])
}

model PortfolioPosition {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [telegramId], onDelete: Cascade)
  exchange  String
  pair      String
  side      String    @default("long") // 'long' | 'short'
  sizeUsd   Float
  leverage  Float     @default(1)
  openedAt  DateTime  @default(now())
  closedAt  DateTime?

  @@index([userId])
  @@index([exchange, pair])
}

// Encrypted exchange API credentials. Only `encPayload` (AES-256-GCM of the
// JSON {apiKey, secret}) is persisted — the secret is never stored in
// plaintext and never returned to the client.
model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [telegramId], onDelete: Cascade)
  exchange    String
  label       String?
  encPayload  String
  permissions String   @default("read") // 'read' | 'trade'
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, exchange, label])
  @@index([userId])
}

// History of orders placed via auto-execute (copy-trade) using the user's
// trade-permission exchange keys. Stored for transparency/audit in the app.
model ExecutedOrder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [telegramId], onDelete: Cascade)
  exchange    String
  symbol      String
  side        String   @default("long") // 'long' | 'short'
  notionalUsd Float
  status      String   @default("sent") // 'sent' | 'filled' | 'failed'
  orderId     String?
  raw         String?  // JSON string of the exchange response
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
