# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/funding_finder"

# Server
PORT=3000
NODE_ENV=development

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# JWT (for API authentication)
JWT_SECRET=change-this-to-a-random-secret-in-production

# AI
OPENROUTER_API_KEY=your_openrouter_key_here
AI_MODEL=x-ai/grok-4.1-fast:free

# Exchange defaults
SETTLE=usdt
MIN_FUNDING_ABS=0.0005
MIN_VOLUME_24H=1000

# Crypto Pay
CRYPTO_PAY_API_TOKEN=your_crypto_pay_token_here
CRYPTO_BOT_USERNAME=CryptoBot
CRYPTO_PAY_NETWORK=testnet

# Webhook
WEBHOOK_SECRET=change-this-to-a-random-secret-in-production

# CORS (comma-separated origins)
CORS_ORIGINS=https://t.me,https://telegram.org
